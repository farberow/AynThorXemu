<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/xemu_black"
  android:keepScreenOn="true"
  android:padding="20dp">

  <!--
    Header strip: brand mark + status pill. No wrapper card — the dashboard
    IS the surface, not a card on a surface. The brand is sparse on purpose;
    the bold green lives in the HUD numbers below, not the chrome.
  -->
  <ImageView
    android:id="@+id/dashboard_brand_wedge"
    android:layout_width="28dp"
    android:layout_height="28dp"
    android:contentDescription="@null"
    android:src="@drawable/ic_xemu_x_mark"
    app:tint="@color/xemu_green_500"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent" />

  <TextView
    android:id="@+id/dashboard_brand"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:text="@string/app_name"
    android:textAppearance="@style/TextAppearance.Xemu.Title"
    android:textColor="@color/xemu_green_500"
    android:textSize="20sp"
    app:layout_constraintStart_toEndOf="@id/dashboard_brand_wedge"
    app:layout_constraintTop_toTopOf="@id/dashboard_brand_wedge"
    app:layout_constraintBottom_toBottomOf="@id/dashboard_brand_wedge" />

  <TextView
    android:id="@+id/dashboard_subtitle"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginTop="4dp"
    android:text="dashboard"
    android:textAppearance="@style/TextAppearance.Xemu.Label"
    android:textColor="@color/xemu_text_muted"
    android:textSize="10sp"
    app:layout_constraintStart_toEndOf="@id/dashboard_brand_wedge"
    app:layout_constraintTop_toBottomOf="@id/dashboard_brand" />

  <TextView
    android:id="@+id/dashboard_status"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="idle"
    android:textAppearance="@style/TextAppearance.Xemu.Label"
    android:textColor="@color/xemu_text_muted"
    android:textSize="11sp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="@id/dashboard_brand_wedge"
    app:layout_constraintBottom_toBottomOf="@id/dashboard_subtitle" />

  <!-- Tick-mark divider under the header — subtle HUD cue. -->
  <View
    android:id="@+id/dashboard_divider_top"
    android:layout_width="0dp"
    android:layout_height="1dp"
    android:layout_marginTop="16dp"
    android:background="@color/xemu_green_900"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_subtitle" />

  <!-- Stats row: FPS / CPU / GPU -->
  <LinearLayout
    android:id="@+id/dashboard_stats"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="3"
    android:layout_marginTop="20dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_divider_top">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FPS"
        android:textAppearance="@style/TextAppearance.Xemu.Label"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/dashboard_fps_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textAppearance="@style/TextAppearance.Xemu.Hud.Number" />

    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CPU"
        android:textAppearance="@style/TextAppearance.Xemu.Label"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/dashboard_cpu_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textAppearance="@style/TextAppearance.Xemu.Hud.NumberSmall" />

    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GPU"
        android:textAppearance="@style/TextAppearance.Xemu.Label"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/dashboard_gpu_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textAppearance="@style/TextAppearance.Xemu.Hud.NumberSmall" />

    </LinearLayout>

  </LinearLayout>

  <!-- Slot row -->
  <TextView
    android:id="@+id/dashboard_controls_label"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Save State"
    android:textAppearance="@style/TextAppearance.Xemu.Section"
    android:layout_marginTop="28dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_stats" />

  <LinearLayout
    android:id="@+id/dashboard_slot_row"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginTop="8dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_controls_label">

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_slot_prev"
      style="?attr/materialButtonOutlinedStyle"
      android:layout_width="56dp"
      android:layout_height="56dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:minWidth="0dp"
      android:text="−"
      android:textSize="22sp"
      app:strokeColor="@color/xemu_green_700"
      android:textColor="@color/xemu_text" />

    <TextView
      android:id="@+id/dashboard_slot_label"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="SLOT 1"
      android:textAppearance="@style/TextAppearance.Xemu.Hud.NumberSmall"
      android:textColor="@color/xemu_text"
      android:textSize="22sp" />

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_slot_next"
      style="?attr/materialButtonOutlinedStyle"
      android:layout_width="56dp"
      android:layout_height="56dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:minWidth="0dp"
      android:text="+"
      android:textSize="22sp"
      app:strokeColor="@color/xemu_green_700"
      android:textColor="@color/xemu_text" />

  </LinearLayout>

  <!-- Save / Load — SAVE is the hero wedge CTA. -->
  <LinearLayout
    android:id="@+id/dashboard_save_load_row"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginTop="10dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_slot_row">

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_save"
      style="@style/Widget.Xemu.Button.Wedge"
      android:layout_width="0dp"
      android:layout_height="56dp"
      android:layout_weight="1"
      android:layout_marginEnd="6dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:text="Save" />

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_load"
      style="@style/Widget.Xemu.Button.Wedge.Outlined"
      android:layout_width="0dp"
      android:layout_height="56dp"
      android:layout_weight="1"
      android:layout_marginStart="6dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:text="Load" />

  </LinearLayout>

  <!-- Quick toggles row: Pause/Resume, Reboot -->
  <TextView
    android:id="@+id/dashboard_toggles_label"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Quick"
    android:textAppearance="@style/TextAppearance.Xemu.Section"
    android:layout_marginTop="24dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_save_load_row" />

  <LinearLayout
    android:id="@+id/dashboard_toggles_row"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginTop="8dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_toggles_label">

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_pause"
      style="?attr/materialButtonOutlinedStyle"
      android:layout_width="0dp"
      android:layout_height="52dp"
      android:layout_weight="1"
      android:layout_marginEnd="6dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:text="Pause"
      android:textColor="@color/xemu_text"
      app:strokeColor="@color/xemu_green_700" />

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_reboot"
      style="?attr/materialButtonOutlinedStyle"
      android:layout_width="0dp"
      android:layout_height="52dp"
      android:layout_weight="1"
      android:layout_marginStart="6dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:text="Reboot"
      android:textColor="@color/xemu_warning"
      app:strokeColor="@color/xemu_warning" />

  </LinearLayout>

  <!-- Display section — lives alongside Save State / Quick as a peer group -->
  <TextView
    android:id="@+id/dashboard_display_label"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Display"
    android:textAppearance="@style/TextAppearance.Xemu.Section"
    android:layout_marginTop="24dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_toggles_row" />

  <com.google.android.material.materialswitch.MaterialSwitch
    android:id="@+id/dashboard_fps_switch"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="FPS overlay on main"
    android:textColor="@color/xemu_text"
    android:layout_marginTop="8dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_display_label" />

</androidx.constraintlayout.widget.ConstraintLayout>
