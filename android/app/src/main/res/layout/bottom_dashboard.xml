<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/xemu_black"
  android:keepScreenOn="true">

  <TextView
    android:id="@+id/dashboard_brand"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="@string/app_name"
    android:textColor="@color/xemu_green"
    android:textSize="22sp"
    android:textStyle="bold"
    android:letterSpacing="0.12"
    android:fontFamily="monospace"
    android:layout_marginTop="24dp"
    android:layout_marginStart="24dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent" />

  <TextView
    android:id="@+id/dashboard_subtitle"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="dashboard"
    android:textColor="@color/xemu_text_muted"
    android:textSize="12sp"
    android:letterSpacing="0.25"
    android:fontFamily="monospace"
    app:layout_constraintStart_toStartOf="@id/dashboard_brand"
    app:layout_constraintTop_toBottomOf="@id/dashboard_brand" />

  <TextView
    android:id="@+id/dashboard_fps_label"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="FPS"
    android:textColor="@color/xemu_text_muted"
    android:textSize="14sp"
    android:letterSpacing="0.2"
    android:fontFamily="monospace"
    android:layout_marginTop="32dp"
    android:layout_marginStart="24dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_subtitle" />

  <TextView
    android:id="@+id/dashboard_fps_value"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="—"
    android:textColor="@color/xemu_green"
    android:textSize="72sp"
    android:fontFamily="monospace"
    app:layout_constraintStart_toStartOf="@id/dashboard_fps_label"
    app:layout_constraintTop_toBottomOf="@id/dashboard_fps_label" />

  <LinearLayout
    android:id="@+id/dashboard_thermals"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginEnd="24dp"
    android:layout_marginTop="32dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_subtitle">

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:layout_marginEnd="32dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CPU"
        android:textColor="@color/xemu_text_muted"
        android:textSize="14sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace" />

      <TextView
        android:id="@+id/dashboard_cpu_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="@color/xemu_text"
        android:textSize="32sp"
        android:fontFamily="monospace" />

    </LinearLayout>

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GPU"
        android:textColor="@color/xemu_text_muted"
        android:textSize="14sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace" />

      <TextView
        android:id="@+id/dashboard_gpu_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="@color/xemu_text"
        android:textSize="32sp"
        android:fontFamily="monospace" />

    </LinearLayout>

  </LinearLayout>

  <TextView
    android:id="@+id/dashboard_placeholder"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="save state · quick toggles coming soon"
    android:textColor="@color/xemu_text_muted"
    android:textSize="11sp"
    android:fontFamily="monospace"
    android:layout_marginBottom="24dp"
    android:layout_marginStart="24dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
