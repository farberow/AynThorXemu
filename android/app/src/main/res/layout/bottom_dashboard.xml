<?xml version="1.0" encoding="utf-8"?>
<!--
  Landscape dashboard for Ayn Thor's bottom strip (~1920x480).
  Left column: brand + HUD stats. Right column: two rows of controls.
  No scrolling — everything must fit in one glance.
-->
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/xemu_black"
  android:keepScreenOn="true"
  android:padding="16dp">

  <!-- ── LEFT COLUMN: brand + stats ── -->

  <ImageView
    android:id="@+id/dashboard_brand_wedge"
    android:layout_width="32dp"
    android:layout_height="32dp"
    android:contentDescription="@null"
    android:src="@drawable/ic_xemu_x_mark"
    app:tint="@color/xemu_green_500"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent" />

  <TextView
    android:id="@+id/dashboard_brand"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:text="@string/app_name"
    android:textAppearance="@style/TextAppearance.Xemu.Title"
    android:textColor="@color/xemu_green_500"
    android:textSize="20sp"
    app:layout_constraintStart_toEndOf="@id/dashboard_brand_wedge"
    app:layout_constraintTop_toTopOf="@id/dashboard_brand_wedge"
    app:layout_constraintBottom_toBottomOf="@id/dashboard_brand_wedge" />

  <TextView
    android:id="@+id/dashboard_status"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:text="idle"
    android:textAppearance="@style/TextAppearance.Xemu.Label"
    android:textColor="@color/xemu_text_muted"
    android:textSize="11sp"
    app:layout_constraintStart_toEndOf="@id/dashboard_brand"
    app:layout_constraintTop_toTopOf="@id/dashboard_brand"
    app:layout_constraintBottom_toBottomOf="@id/dashboard_brand" />

    <TextView
        android:id="@+id/dashboard_build_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:fontFeatureSettings="tnum"
        android:gravity="start"
        android:letterSpacing="0.03"
        android:maxLines="1"
        android:text="BUILD v1.2.4 • thor-2026-04-18.01"
        android:textAppearance="@style/TextAppearance.Xemu.Label"
        android:textColor="@color/xemu_text_muted"
        android:textSize="11sp"
        app:layout_constraintEnd_toStartOf="@id/dashboard_column_divider"
        app:layout_constraintStart_toStartOf="@id/dashboard_brand"
        app:layout_constraintTop_toBottomOf="@id/dashboard_brand_wedge" />

  <!-- Stats row — FPS hero + CPU/GPU small, all inline -->
  <LinearLayout
    android:id="@+id/dashboard_stats"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    android:orientation="horizontal"
    android:gravity="bottom"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toStartOf="@id/dashboard_column_divider"
    app:layout_constraintTop_toBottomOf="@id/dashboard_build_number">

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FPS"
        android:textAppearance="@style/TextAppearance.Xemu.Label"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/dashboard_fps_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textAppearance="@style/TextAppearance.Xemu.Hud.Number"
        android:textSize="44sp"
        android:includeFontPadding="false" />

    </LinearLayout>

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="28dp"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CPU"
        android:textAppearance="@style/TextAppearance.Xemu.Label"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/dashboard_cpu_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textAppearance="@style/TextAppearance.Xemu.Hud.NumberSmall"
        android:textSize="24sp"
        android:includeFontPadding="false" />

    </LinearLayout>

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="20dp"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GPU"
        android:textAppearance="@style/TextAppearance.Xemu.Label"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/dashboard_gpu_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textAppearance="@style/TextAppearance.Xemu.Hud.NumberSmall"
        android:textSize="24sp"
        android:includeFontPadding="false" />

    </LinearLayout>

  </LinearLayout>

  <!-- Vertical divider splitting left/right columns -->
  <View
    android:id="@+id/dashboard_column_divider"
    android:layout_width="1dp"
    android:layout_height="0dp"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp"
    android:background="@color/xemu_green_900"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintHorizontal_bias="0.42"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent" />

  <!-- ── RIGHT COLUMN: controls ── -->

  <!-- Slot + Save/Load row -->
  <TextView
    android:id="@+id/dashboard_controls_label"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Save State"
    android:textAppearance="@style/TextAppearance.Xemu.Section"
    app:layout_constraintStart_toEndOf="@id/dashboard_column_divider"
    app:layout_constraintTop_toTopOf="parent" />

  <LinearLayout
    android:id="@+id/dashboard_slot_row"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginTop="8dp"
    app:layout_constraintStart_toEndOf="@id/dashboard_column_divider"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_controls_label">

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_slot_prev"
      style="?attr/materialButtonOutlinedStyle"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:minWidth="0dp"
      android:padding="0dp"
      android:text="−"
      android:textSize="22sp"
      app:strokeColor="@color/xemu_green_700"
      android:textColor="@color/xemu_text" />

    <TextView
      android:id="@+id/dashboard_slot_label"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="SLOT 1"
      android:textAppearance="@style/TextAppearance.Xemu.Hud.NumberSmall"
      android:textColor="@color/xemu_text"
      android:textSize="20sp" />

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_slot_next"
      style="?attr/materialButtonOutlinedStyle"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:minWidth="0dp"
      android:padding="0dp"
      android:text="+"
      android:textSize="22sp"
      app:strokeColor="@color/xemu_green_700"
      android:textColor="@color/xemu_text"
      android:layout_marginStart="6dp" />

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_save"
      style="@style/Widget.Xemu.Button.Wedge"
      android:layout_width="0dp"
      android:layout_height="48dp"
      android:layout_weight="1.2"
      android:layout_marginStart="10dp"
      android:paddingStart="14dp"
      android:paddingEnd="14dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:text="Save" />

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_load"
      style="@style/Widget.Xemu.Button.Wedge.Outlined"
      android:layout_width="0dp"
      android:layout_height="48dp"
      android:layout_weight="1.2"
      android:layout_marginStart="6dp"
      android:paddingStart="14dp"
      android:paddingEnd="14dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:text="Load" />

  </LinearLayout>

  <!-- Quick actions row -->
  <TextView
    android:id="@+id/dashboard_toggles_label"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Quick"
    android:textAppearance="@style/TextAppearance.Xemu.Section"
    android:layout_marginTop="16dp"
    app:layout_constraintStart_toEndOf="@id/dashboard_column_divider"
    app:layout_constraintTop_toBottomOf="@id/dashboard_slot_row" />

  <LinearLayout
    android:id="@+id/dashboard_toggles_row"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginTop="8dp"
    app:layout_constraintStart_toEndOf="@id/dashboard_column_divider"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/dashboard_toggles_label">

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_pause"
      style="?attr/materialButtonOutlinedStyle"
      android:layout_width="0dp"
      android:layout_height="46dp"
      android:layout_weight="1"
      android:paddingStart="8dp"
      android:paddingEnd="8dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:text="Pause"
      android:textColor="@color/xemu_text"
      app:strokeColor="@color/xemu_green_700" />

    <com.google.android.material.button.MaterialButton
      android:id="@+id/dashboard_reboot"
      style="?attr/materialButtonOutlinedStyle"
      android:layout_width="0dp"
      android:layout_height="46dp"
      android:layout_weight="1"
      android:layout_marginStart="6dp"
      android:paddingStart="8dp"
      android:paddingEnd="8dp"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:text="Reboot"
      android:textColor="@color/xemu_warning"
      app:strokeColor="@color/xemu_warning" />

    <com.google.android.material.materialswitch.MaterialSwitch
      android:id="@+id/dashboard_fps_switch"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="12dp"
      android:text="FPS"
      android:textColor="@color/xemu_text" />

  </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
