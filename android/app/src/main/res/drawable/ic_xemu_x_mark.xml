<!--
  Stylized Xbox-style X mark — jewel silhouette with a diagonal X cut.
  Single-tone vector (tint via app:tint) so it inherits accent colors.
  Use sparingly: brand header, boot splash — one per screen.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
  android:width="24dp"
  android:height="24dp"
  android:viewportWidth="24"
  android:viewportHeight="24"
  android:tint="?attr/colorPrimary">

  <!-- Outer jewel ring (diamond rotated square) -->
  <path
    android:pathData="M12,1.5 L22.5,12 L12,22.5 L1.5,12 Z M12,5.0 L5.0,12 L12,19.0 L19.0,12 Z"
    android:fillColor="#FFFFFFFF"
    android:fillType="evenOdd" />

  <!-- X strokes inside -->
  <path
    android:pathData="M8,8 L16,16"
    android:strokeColor="#FFFFFFFF"
    android:strokeWidth="2.2"
    android:strokeLineCap="round" />
  <path
    android:pathData="M16,8 L8,16"
    android:strokeColor="#FFFFFFFF"
    android:strokeWidth="2.2"
    android:strokeLineCap="round" />

</vector>
